# ── Core ─────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/expense_tracker?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# ── Email — OPTION A: Brevo (recommended, free 300/day) ──────
# 1. Sign up free at https://app.brevo.com
# 2. Go to SMTP & API → SMTP tab
# 3. Copy the SMTP credentials shown there
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@email.com
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=noreply@yourdomain.com

# ── Email — OPTION B: Gmail App Password (fallback) ──────────
# Only used if SMTP_HOST is not set.
# Requires 2FA on Google account + App Password from:
#   https://myaccount.google.com/apppasswords
EMAIL_USER=your@gmail.com
EMAIL_PASS=16charapppassword
