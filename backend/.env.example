# Copy this file to .env and fill in your values
# DO NOT commit .env to git

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/expense_tracker?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# Email (Gmail SMTP) — required for email verification and password reset
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
# 4. Paste the 16-character password below (no spaces)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
